{
  "name": "voxelrt",
  "version": "0.1.0",
  "description": "Real-time path-traced global illumination for 1/16 m voxels, rendered with WebGPU compute shaders",
  "type": "module",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 .",
    "test": "node test/screenshot.mjs",
    "test:manifest": "node --test test/claim-manifest.test.mjs",
    "check": "node test/check.mjs && node --test test/claim-manifest.test.mjs",
    "bench": "node test/bench.mjs --suite smoke",
    "bench:baseline": "node test/bench.mjs --suite convergence --resolution 1920x1080 --scale 1 --flip --repeats 5 --scenarios interior_static,interior_move,exterior_static,exterior_move,lamps_static,lamps_move --configs base,gi,lin,ours_unbiased,ours",
    "bench:ladder": "node test/bench.mjs --resolution 1920x1080 --scale 1 --flip --frames 32 --repeats 3 --ref-frames 64 --scenarios interior_static,lamps_static,exterior_move --configs ours,ours_sigma32,ours_adaptcand,ours_lightgrid,ours_adapt_lightgrid,ours_no_dup,ours_mutate",
    "bench:ladder:confdenoise": "node test/bench.mjs --resolution 1920x1080 --scale 1 --flip --frames 32 --repeats 3 --ref-frames 64 --denoise 1 --scenarios interior_move,exterior_move,lamps_move --configs ours,ours_confdenoise",
    "bench:preflight": "node test/bench.mjs --claim-preflight",
    "bench:references": "node test/bench.mjs --claim --validate-refs",
    "bench:references:checkpoints": "node test/bench.mjs --validate-refs --validate-ref-checkpoints --resolution 1920x1080 --scale 1",
    "bench:correctness": "node test/bench.mjs --claim --suite correctness",
    "analyze": "node test/analyze.mjs",
    "analyze:cost": "node test/analyze.mjs --cost-table",
    "bench:ablation": "node test/bench.mjs --suite ablation --resolution 1920x1080 --scale 1 --flip",
    "bench:convergence": "node test/bench.mjs --suite convergence --resolution 1920x1080 --scale 1 --flip"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}

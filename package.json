{
  "name": "voxelrt",
  "version": "0.1.0",
  "description": "Real-time path-traced global illumination for 1/16 m voxels, rendered with WebGPU compute shaders",
  "type": "module",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 .",
    "test": "node test/screenshot.mjs",
    "test:manifest": "node --test test/claim-manifest.test.mjs",
    "bench": "node test/bench.mjs --suite smoke",
    "bench:preflight": "node test/bench.mjs --claim-preflight",
    "bench:references": "node test/bench.mjs --claim --validate-refs",
    "bench:correctness": "node test/bench.mjs --claim --suite correctness",
    "bench:ablation": "node test/bench.mjs --suite ablation --resolution 1920x1080 --scale 1 --flip",
    "bench:convergence": "node test/bench.mjs --suite convergence --resolution 1920x1080 --scale 1 --flip"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}
